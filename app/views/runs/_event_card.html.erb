<% 
  icon = case event.icon_type
         when "heart" then "❤️"
         when "sparkles" then "✨"
         when "briefcase" then "💼"
         when "skull" then "💀"
         when "info" then "ℹ️"
         else "⚡"
         end
%>

<div class="event-card <%= active ? 'active' : 'past' %>" id="event_<%= event.id %>">
  <div class="event-left">
    <span class="event-age">AGE <%= event.age %></span>
    <div class="event-icon-wrapper">
      <%= icon %>
    </div>
  </div>

  <div class="event-right">
    <h3 class="event-title"><%= event.title %></h3>
    <p class="event-narrative"><%= event.narrative %></p>

    <% if active && event.run.status == "active" %>
      <div class="event-choices">
        <% event.choices.each_with_index do |choice, idx| %>
          <%= button_to play_run_path(event.run), 
                        params: { choice_id: choice["id"] }, 
                        method: :post, 
                        class: "choice-btn",
                        form: { class: "choice-form" } do %>
            <span class="choice-indicator">></span>
            <span><%= choice["text"] %></span>
            <% if choice["preview"].present? %>
              <span class="choice-preview"><%= choice["preview"] %></span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <!-- Past event resolution -->
      <% if event.selected_choice_id.present? || event.player_custom_action.present? %>
        <div class="resolution-box">
          <div class="resolution-action">
            Action : 
            <% if event.player_custom_action.present? %>
              "<%= event.player_custom_action %>"
            <% else %>
              <% selected_choice = event.choices.find { |c| c["id"] == event.selected_choice_id } %>
              "<%= selected_choice ? selected_choice["text"] : event.selected_choice_id %>"
            <% end %>
          </div>
          <% if event.resolution_narrative.present? %>
            <div style="margin-top: 8px; line-height: 1.5;"><%= event.resolution_narrative %></div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
