<% events.reverse.each_with_index do |event, idx| %>
  <div class="timeline-item <%= idx == 0 ? 'active' : '' %>">
    <div class="timeline-dot"></div>
    <div class="timeline-content">
      <span class="timeline-age">AGE <%= event.age %></span>
      <span class="timeline-text" title="<%= event.narrative %>">
        <strong><%= event.title %></strong> - <%= event.narrative %>
      </span>
    </div>
  </div>
<% end %>
